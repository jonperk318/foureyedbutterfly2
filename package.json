    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.10",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "vite": "^8.0.6"
