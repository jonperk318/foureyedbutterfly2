{
  "name": "tanstack-router-react-example-with-trpc-react-query",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:server && pnpm run build:client",
    "build:client": "vite build && tsc --noEmit",
    "build:server": "vite build --mode server",
    "dev": "pnpm tsx ./src/server/server.ts --watch",
    "prettier": "npx prettier . --write",
    "start": "NODE_ENV=production node dist/server/server.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.7",
    "@clerk/react": "^6.2.0",
    "@clerk/ui": "^1.4.0",
    "@imagekit/nodejs": "^7.4.0",
    "@imagekit/react": "^5.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/router-plugin": "^1.167.12",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jotai": "^2.19.0",
    "motion": "^12.38.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "redaxios": "^0.5.1",
    "tailwindcss": "^4.2.2",
    "utf-8-validate": "^6.0.6",
    "zod": "^4.3.6"
  },
